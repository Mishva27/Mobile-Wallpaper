<?xml version="1.0" encoding="utf-8"?>
<!-- Selectable card for the Static / Moving style options. Brand outline when
     selected; a subtle divider outline otherwise. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface_variant" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke android:width="2dp" android:color="@color/brand_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_surface_variant" />
            <corners android:radius="@dimen/radius_lg" />
            <stroke android:width="1dp" android:color="@color/divider" />
        </shape>
    </item>
</selector>
