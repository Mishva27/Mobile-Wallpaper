<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base dark theme. The app is dark-only, so both values/ and values-night/
         resolve to the same dark palette. -->
    <style name="Base.Theme.MobileWallpaper" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_variant</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_root</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Edge-to-edge, transparent system bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.MobileWallpaper" parent="Base.Theme.MobileWallpaper" />

    <!-- Splash theme backed by the modern SplashScreen API.
         The window background is the dark gradient so the cold-start frame is never
         white, and the system splash icon is the real app icon on a dark background. -->
    <style name="Theme.MobileWallpaper.Splash" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="windowSplashScreenBackground">@color/splash_gradient_start</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/app_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.MobileWallpaper.Splash.Post</item>
    </style>

    <!-- After the system splash, keep the dark gradient window background so there is
         no flash before the splash layout draws. -->
    <style name="Theme.MobileWallpaper.Splash.Post" parent="Theme.MobileWallpaper">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
    </style>

    <!-- Rounded corners for the app icon on the splash. -->
    <style name="RoundedIconShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/radius_xl</item>
    </style>

    <!-- Toolbar title styling -->
    <style name="ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Detail action button column -->
    <style name="DetailActionColumn">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:paddingHorizontal">@dimen/space_md</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="DetailActionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_xs</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- Bottom-sheet target rows -->
    <style name="SheetRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:background">@drawable/bg_sheet_row</item>
        <item name="android:padding">@dimen/space_md</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="SheetRowIcon">
        <item name="android:layout_width">46dp</item>
        <item name="android:layout_height">46dp</item>
        <item name="android:background">@drawable/bg_icon_tile_brand</item>
        <item name="android:padding">@dimen/space_sm</item>
        <item name="android:contentDescription">@null</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="SheetRowLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/space_lg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- Bottom-sheet style dialogs -->
    <style name="RoundedBottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="shapeAppearance">@style/BottomSheetShape</item>
    </style>

    <style name="BottomSheetShape" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSizeTopLeft">@dimen/radius_xl</item>
        <item name="cornerSizeTopRight">@dimen/radius_xl</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
</resources>
