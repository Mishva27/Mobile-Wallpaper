<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/bg_elevated"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_card">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_xl"
        android:paddingTop="@dimen/space_lg"
        android:paddingEnd="@dimen/space_xl"
        android:paddingBottom="@dimen/space_lg">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorColor="@color/brand_primary"
            app:indicatorSize="32dp"
            app:trackThickness="3dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/tvProgressMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_lg"
            android:maxWidth="220dp"
            android:text="@string/progress_please_wait"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
