<?xml version="1.0" encoding="utf-8"?>
<!--
    Bottom-nav shell. A full-bleed fragment container hosts the Wallpapers, Live,
    Favorites and Settings tabs; the floating pill-shaped bar sits on top, anchored
    to the bottom with side margins so it appears to hover above the content.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_root">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <include
        android:id="@+id/bottomNav"
        layout="@layout/view_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/bottom_nav_margin"
        android:layout_marginEnd="@dimen/bottom_nav_margin"
        android:layout_marginBottom="@dimen/bottom_nav_margin" />

</FrameLayout>
