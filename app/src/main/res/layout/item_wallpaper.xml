<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/grid_gap"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="@dimen/_2sdp"
    app:rippleColor="@color/brand_primary">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Height is assigned per-position in WallpaperAdapter to create the
             staggered mosaic; the value here is only a design-time default. -->
        <ImageView
            android:id="@+id/ivWallpaper"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_220sdp"
            android:background="@color/placeholder_bg"
            android:contentDescription="@string/cd_wallpaper_image"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:id="@+id/wallpaperLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:indicatorColor="@color/brand_primary"
                app:indicatorSize="@dimen/_26sdp"
                app:trackThickness="@dimen/_2sdp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:text="@string/progress_loading"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_caption" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="@dimen/space_sm"
            android:background="@drawable/bg_pro_badge"
            android:paddingHorizontal="@dimen/space_sm"
            android:paddingVertical="@dimen/_2sdp"
            android:text="@string/pro_badge"
            android:textColor="@color/pro_badge_text"
            android:textSize="@dimen/text_badge"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
