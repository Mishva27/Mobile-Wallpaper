<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- The pager occupies ~60% of the screen; 0.767 of that ≈ 46% image / 14% text. -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gImageBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.767" />

    <!-- Gradient border: the frame's background shows as a 2dp edge around the
         rounded image inside it. -->
    <FrameLayout
        android:id="@+id/imageBorder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/space_xl"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginBottom="@dimen/space_md"
        android:background="@drawable/bg_gradient_border"
        android:padding="@dimen/_2sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gImageBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivOnboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/cd_onboarding_image"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/OnboardImageShape"
            tools:src="@drawable/onboarding_1" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_xl"
        app:layout_constraintTop_toBottomOf="@id/gImageBottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/_24ssp"
            android:textStyle="bold"
            tools:text="Set in a Tap" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:lineSpacingMultiplier="1.2"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body"
            tools:text="Apply any wallpaper to your home, lock, or both screens instantly." />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
